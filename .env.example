# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL (usado nos callbacks OAuth) ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Meta Ads (Meta for Developers → Meu App → Configurações) ────────────────
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Callback registrado no Meta: {APP_URL}/api/auth/meta/callback
# Scopes necessários: ads_management, ads_read, business_management

# ─── Google Ads (console.cloud.google.com → Credenciais OAuth 2.0) ───────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
# Callback registrado no Google: {APP_URL}/api/auth/google-ads/callback
# Scope necessário: https://www.googleapis.com/auth/adwords

# ─── Cron Secret (protege /api/cron/evaluate-rules) ──────────────────────────
# Gere com: openssl rand -base64 32
CRON_SECRET=your-random-secret-here
