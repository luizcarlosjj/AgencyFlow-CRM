# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App URL (usado nos callbacks OAuth) ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Chave de criptografia AES-256-GCM ───────────────────────────────────────
# Usada para criptografar credenciais de API de cada agência no banco.
# CRÍTICO: nunca altere em produção — dados existentes ficam ilegíveis.
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key-here

# ─── Cron (protege /api/cron/evaluate-rules) ─────────────────────────────────
# Gere com: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# ─── Credenciais de API por agência ──────────────────────────────────────────
# Meta App ID/Secret e Google Client ID/Secret/Developer Token NÃO ficam mais
# aqui. Cada agência cadastra suas próprias credenciais em:
# Configurações → Credenciais de API
# Elas são criptografadas com ENCRYPTION_KEY antes de serem salvas no banco.
